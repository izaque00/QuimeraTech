# ═══════════════════════════════════════════════════════════════
# Quimera — .env.example (TEMPLATE — NUNCA commitar chaves reais)
# ═══════════════════════════════════════════════════════════════
# 
# Como usar:
#   1. Copie este arquivo para .env:  cp .env.example .env
#   2. Configure o Vault:             quimera vault init
#   3. Adicione chaves:               quimera vault add OPENAI_API_KEY sk-...
#
# ⚠️  NUNCA coloque chaves reais neste arquivo.
# ⚠️  .env e .vault estão no .gitignore.
# ═══════════════════════════════════════════════════════════════

# ── Vault (cofre criptografado) ──
VAULT_KEY=sua-senha-mestra-aqui
# QUIMERA_VAULT_PATH=.vault  # (padrão: .vault)

# ═══════════════════════════════════════════════════════════════
# Abaixo: referência de quais chaves o Quimera suporta.
# Coloque as chaves REAIS no Vault, não aqui.
# ═══════════════════════════════════════════════════════════════

# ── OpenAI ──
# quimera vault add OPENAI_API_KEY_1 sk-...
# quimera vault add OPENAI_API_KEY_2 sk-...
# quimera vault add OPENAI_API_KEY_3 sk-...

# ── Anthropic ──
# quimera vault add ANTHROPIC_API_KEY_1 sk-ant-...
# quimera vault add ANTHROPIC_API_KEY_2 sk-ant-...

# ── Google (Gemini) ──
# quimera vault add GOOGLE_API_KEY_1 AIza...
# quimera vault add GOOGLE_API_KEY_2 AIza...

# ── Groq (inferência rápida, tier gratuito generoso) ──
# quimera vault add GROQ_API_KEY_1 gsk_...
# quimera vault add GROQ_API_KEY_2 gsk_...

# ── DeepSeek ──
# quimera vault add DEEPSEEK_API_KEY_1 sk-...
# quimera vault add DEEPSEEK_API_KEY_2 sk-...

# ── Together AI ──
# quimera vault add TOGETHER_API_KEY_1 ...
# quimera vault add TOGETHER_API_KEY_2 ...

# ── Ollama (local, não precisa de chave) ──
# OLLAMA_ENDPOINT=http://localhost:11434

# ── HuggingFace ──
# quimera vault add HUGGINGFACE_API_KEY_1 hf_...
# quimera vault add HUGGINGFACE_API_KEY_2 hf_...

# ── Fireworks AI ──
# quimera vault add FIREWORKS_API_KEY_1 ...

# ── Mistral ──
# quimera vault add MISTRAL_API_KEY_1 ...

# ── Cohere ──
# quimera vault add COHERE_API_KEY_1 ...

# ── OpenRouter ──
# quimera vault add OPENROUTER_API_KEY sk-or-v1-...

# ── Cerebras ──
# quimera vault add CEREBRAS_API_KEY ...

# ═══════════════════════════════════════════════════════════════
# Configuração do Roteador de Modelos
# ═══════════════════════════════════════════════════════════════

ROUTER_MAX_RPM_PER_KEY=50
ROUTER_TIMEOUT_SECONDS=30
ROUTER_MAX_RETRIES_PER_KEY=3
ROUTER_KEY_COOLDOWN_SECONDS=60
ROUTER_PRIORITY=openai,groq,anthropic,deepseek,together,google,mistral,cohere,fireworks,huggingface,ollama
ROUTER_FREE_TIER_FIRST=true
